<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.qqsystem.serve.mapper.ContentMapper">

    <select id="selectById" resultType="com.qqsystem.serve.entity.Content">
        SELECT *
        FROM content
        WHERE id = #{id}
    </select>

</mapper>