<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.qqsystem.serve.mapper.LoginLogMapper">
    <insert id="insertLoginLog" parameterType="com.qqsystem.serve.entity.LoginLog">
        INSERT INTO login_log (user_id, ip, device, login_time)
        VALUES (#{userId}, #{ip}, #{device}, #{loginTime})
    </insert>
</mapper>