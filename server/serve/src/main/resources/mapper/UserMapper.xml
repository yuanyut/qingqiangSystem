<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.qqsystem.serve.mapper.UserMapper">

    <select id="selectByUsername" resultType="com.qqsystem.serve.entity.User">
        SELECT *
        FROM user
        WHERE username = #{username}
            LIMIT 1
    </select>
    <select id="selectById" resultType="com.qqsystem.serve.entity.User">
        SELECT *
        FROM user
        WHERE id = #{userId}
    </select>
    <insert id="insert" parameterType="com.qqsystem.serve.entity.User">
        INSERT INTO user (
            username,
            password,
            nickname,
            sex,
            birthday,
            status
        ) VALUES (
                     #{username},
                     #{password},
                     #{nickname},
                     #{sex},
                     #{birthday},
                     #{status}
                 )
    </insert>
</mapper>